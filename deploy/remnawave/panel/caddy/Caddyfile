# Remnawave reverse proxy (Caddy)
# DNS: host `panel` и `sub` (32-network.online) → IP этого сервера; Let's Encrypt при корректных A/AAAA.
#
# Источник примеров: https://docs.rw/docs/install/subscription-page/bundled (секция Caddy)
#
# Remnawave проверяет reverse proxy + HTTPS (ProxyCheckMiddleware): нужны
# X-Forwarded-Proto / X-Forwarded-Host, как в доке Nginx:
# https://docs.rw/docs/install/subscription-page/bundled
#
# За Cloudflare см. deploy/remnawave/panel/Caddyfile (CF-Connecting-IP).

https://panel.32-network.online {
  reverse_proxy * http://remnawave:3000 {
    header_up Host {http.request.host}
    header_up X-Forwarded-Host {http.request.host}
    header_up X-Forwarded-Proto https
    header_up X-Real-IP {http.request.remote.host}
    header_up X-Forwarded-For {http.request.remote.host}
  }
}

https://sub.32-network.online {
  reverse_proxy * http://remnawave-subscription-page:3010 {
    header_up Host {http.request.host}
    header_up X-Forwarded-Host {http.request.host}
    header_up X-Forwarded-Proto https
    header_up X-Real-IP {http.request.remote.host}
    header_up X-Forwarded-For {http.request.remote.host}
  }
}
