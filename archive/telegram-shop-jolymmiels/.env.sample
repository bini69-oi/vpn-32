# ===================== Remnawave Telegram Shop =====================
# Скопируй этот файл в .env и заполни реальными значениями.
# Полный список переменных: https://github.com/Jolymmiels/remnawave-telegram-shop#environment-variables

# ---- Telegram ----
TELEGRAM_TOKEN=PUT_BOT_TOKEN_FROM_BOTFATHER
ADMIN_TELEGRAM_ID=123456789

# ---- Цены (RUB) ----
PRICE_1=150
PRICE_3=400
PRICE_6=700
PRICE_12=1200

# ---- Цены в Telegram Stars ----
STARS_PRICE_1=150
STARS_PRICE_3=400
STARS_PRICE_6=700
STARS_PRICE_12=1200

DAYS_IN_MONTH=30
DEFAULT_LANGUAGE=ru

# ---- Триал (0 = выключен) ----
TRIAL_DAYS=3
TRIAL_TRAFFIC_LIMIT=10
TRIAL_REMNAWAVE_TAG=
TRIAL_INTERNAL_SQUADS=
TRIAL_EXTERNAL_SQUAD_UUID=
TRIAL_TRAFFIC_LIMIT_RESET_STRATEGY=MONTH

# ---- Реф-программа (0 = выключена) ----
REFERRAL_DAYS=7

# ---- Remnawave Panel ----
# URL панели. Если бот и панель на одном хосте в одной docker-сети —
# можно указать http://remnawave:3000 и REMNAWAVE_MODE=local.
REMNAWAVE_URL=https://panel.example.com
REMNAWAVE_MODE=remote
REMNAWAVE_TOKEN=PUT_REMNAWAVE_API_TOKEN
REMNAWAVE_TAG=SHOP
REMNAWAVE_HEADERS=

# Какие Internal/External Squad назначать пользователю.
# Если пусто — назначаются все доступные.
SQUAD_UUIDS=
EXTERNAL_SQUAD_UUID=

# Лимит трафика (ГБ), 0 = безлимит
TRAFFIC_LIMIT=0
TRAFFIC_LIMIT_RESET_STRATEGY=MONTH

# ---- БД (оставь как есть для docker-compose) ----
DATABASE_URL=postgres://postgres:postgres@db:5432/postgres?sslmode=disable
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---- Платёжные системы ----
TELEGRAM_STARS_ENABLED=true
REQUIRE_PAID_PURCHASE_FOR_STARS=false

CRYPTO_PAY_ENABLED=false
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_URL=https://pay.crypt.bot

YOOKASA_ENABLED=false
YOOKASA_SECRET_KEY=
YOOKASA_SHOP_ID=
YOOKASA_URL=https://api.yookassa.ru/v3
YOOKASA_EMAIL=

# Tribute (нужен публичный домен + HTTPS)
TRIBUTE_WEBHOOK_URL=
TRIBUTE_API_KEY=
TRIBUTE_PAYMENT_URL=

# ---- Веб-сервер (healthcheck / webhooks) ----
# Любой свободный порт 1..65535. Внутри docker-сети достаточно, наружу
# пробрасывать не обязательно (для Tribute-вебхука нужен reverse-proxy).
HEALTH_CHECK_PORT=8080
IS_WEB_APP_LINK=false
MINI_APP_URL=

# ---- Публичные ссылки (необязательно) ----
SERVER_STATUS_URL=
SUPPORT_URL=
FEEDBACK_URL=
CHANNEL_URL=
TOS_URL=

# ---- Списки ID (через запятую) ----
BLOCKED_TELEGRAM_IDS=
WHITELISTED_TELEGRAM_IDS=

# ---- Прокси (опционально) ----
TELEGRAM_PROXY_URL=
MOYNALOG_PROXY_URL=
